<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.4.3</version>
        <relativePath/>
    </parent>

    <groupId>com.wandocorp</groupId>
    <artifactId>nyt-scorebot</artifactId>
    <version>1.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <modules>
        <module>nyt-scorebot-domain</module>
        <module>nyt-scorebot-database</module>
        <module>nyt-scorebot-service</module>
        <module>nyt-scorebot-discord</module>
        <module>nyt-scorebot-app</module>
    </modules>

    <properties>
        <java.version>17</java.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <discord4j-core.version>3.2.7</discord4j-core.version>
        <lombok.version>1.18.38</lombok.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.wandocorp</groupId>
                <artifactId>nyt-scorebot-domain</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.wandocorp</groupId>
                <artifactId>nyt-scorebot-database</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.wandocorp</groupId>
                <artifactId>nyt-scorebot-service</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.wandocorp</groupId>
                <artifactId>nyt-scorebot-discord</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.discord4j</groupId>
                <artifactId>discord4j-core</artifactId>
                <version>${discord4j-core.version}</version>
            </dependency>
            <dependency>
                <groupId>org.projectlombok</groupId>
                <artifactId>lombok</artifactId>
                <version>${lombok.version}</version>
                <scope>provided</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                            <version>${lombok.version}</version>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <!-- Allow ByteBuddy to load its instrumentation agent at runtime,
                         which Mockito inline mock maker requires on Java 21+. -->
                    <argLine>-XX:+EnableDynamicAgentLoading --add-opens java.base/java.lang=ALL-UNNAMED -Dnet.bytebuddy.experimental=true @{argLine}</argLine>
                    <failIfNoSpecifiedTests>false</failIfNoSpecifiedTests>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.12</version>
                <configuration>
                    <excludes>
                        <exclude>com/wandocorp/nytscorebot/model/**</exclude>
                        <exclude>com/wandocorp/nytscorebot/entity/User.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/entity/Scoreboard.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/entity/PersonalBest.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/entity/PersonalBestSource.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/repository/**</exclude>
                        <exclude>com/wandocorp/nytscorebot/service/SaveOutcome.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/NytScorebotApplication.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/DiscordConfig.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/config/DiscordConfig.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/config/DiscordChannelProperties*.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/listener/SlashCommandRegistrar.class</exclude>
                        <exclude>**/entity/**$HibernateProxy*</exclude>
                        <exclude>**/entity/**$HibernateInstantiator*</exclude>
                        <!-- Stats DTOs, records and simple exception -->
                        <exclude>com/wandocorp/nytscorebot/service/stats/CrosswordStatsReport*.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/service/stats/GameTypeFilter.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/service/stats/StatsWindowBeforeAnchorException.class</exclude>
                        <exclude>com/wandocorp/nytscorebot/config/StatsProperties.class</exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <id>prepare-agent</id>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>check</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>INSTRUCTION</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.80</minimum>
                                        </limit>
                                        <limit>
                                            <counter>BRANCH</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>0.80</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>